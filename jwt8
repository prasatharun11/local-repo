            when(springJwt.getAudience()).thenReturn(List.of("abc-application"));
            when(springJwt.getClaims()).thenReturn(Map.of("sub", "user@example.com"));

            ValidationResult result = strategy.validate("token");

            assertTrue(result.isValid());
            verify(decoder2, never()).decode(any());
        }

        @Test
        void firstDecoderFails_secondMatches_returnsSuccess() {
            JwksValidationStrategy strategy =
                new JwksValidationStrategy(List.of(decoder1, decoder2), "abc-application");

            when(decoder1.decode("token")).thenThrow(new JwtException("bad sig"));
            when(decoder2.decode("token")).thenReturn(springJwt);
            when(springJwt.getAudience()).thenReturn(List.of("abc-application"));
            when(springJwt.getClaims()).thenReturn(Map.of("sub", "user@example.com"));

            ValidationResult result = strategy.validate("token");

            assertTrue(result.isValid());
            verify(decoder1).decode("token");
            verify(decoder2).decode("token");
        }

        @Test
        void allDecodersFail_returnsFailure() {
            JwksValidationStrategy strategy =
                new JwksValidationStrategy(List.of(decoder1, decoder2), "abc-application");

            when(decoder1.decode("token")).thenThrow(new JwtException("expired"));
            when(decoder2.decode("token")).thenThrow(new JwtException("bad sig"));

            ValidationResult result = strategy.validate("token");

            assertFalse(result.isValid());
            assertNotNull(result.getErrorMessage());
        }

        @Test
        void audienceMismatch_movesToNextDecoder() {
            JwksValidationStrategy strategy =
                new JwksValidationStrategy(List.of(decoder1, decoder2), "abc-application");

            when(decoder1.decode("token")).thenReturn(springJwt);
            when(springJwt.getAudience()).thenReturn(List.of("wrong-audience"));
            when(decoder2.decode("token")).thenThrow(new JwtException("bad sig"));

            ValidationResult result = strategy.validate("token");

            assertFalse(result.isValid());
            verify(decoder1).decode("token");
            verify(decoder2).decode("token");
        }

        @Test
        void nullAudience_skipsAudienceCheck_returnsSuccess() {
            JwksValidationStrategy strategy =
                new JwksValidationStrategy(List.of(decoder1), null);

            when(decoder1.decode("token")).thenReturn(springJwt);
            when(springJwt.getClaims()).thenReturn(Map.of("sub", "user@example.com"));

            ValidationResult result = strategy.validate("token");

            assertTrue(result.isValid());
        }

        @Test
        void validToken_claimsAreCopied() {
            JwksValidationStrategy strategy =
                new JwksValidationStrategy(List.of(decoder1), "abc-application");

            Map<String, Object> claims = Map.of("sub", "user@example.com", "scp", "read:items");
            when(decoder1.decode("token")).thenReturn(springJwt);
            when(springJwt.getAudience()).thenReturn(List.of("abc-application"));
            when(springJwt.getClaims()).thenReturn(claims);

            assertEquals(claims, strategy.validate("token").getClaims());
        }
    }
}

