class ExpiryOnlyValidationStrategyTest {

    private ExpiryOnlyValidationStrategy strategy;

    @BeforeEach
    void setUp() { strategy = new ExpiryOnlyValidationStrategy(); }

    private String buildJwt(Long expEpochSecond, String extraClaims) {
        String header  = Base64.getUrlEncoder().withoutPadding()
            .encodeToString("{\"alg\":\"RS256\"}".getBytes());
        String payloadJson = "{\"sub\":\"user@example.com\""
            + (expEpochSecond != null ? ",\"exp\":" + expEpochSecond : "")
            + (extraClaims != null ? "," + extraClaims : "")
            + "}";
        String payload = Base64.getUrlEncoder().withoutPadding()
            .encodeToString(payloadJson.getBytes());
        return header + "." + payload + ".fakesig";
    }

    @Nested
    class ValidToken {
        @Test
        void nonExpiredToken_returnsSuccess() {
            String token = buildJwt(Instant.now().plusSeconds(3600).getEpochSecond(), null);
            assertTrue(strategy.validate(token).isValid());
        }

        @Test
        void validToken_subjectInClaims() {
            String token = buildJwt(Instant.now().plusSeconds(3600).getEpochSecond(), null);
            assertEquals("user@example.com", strategy.validate(token).getClaims().get("sub"));
        }

        @Test
        void validToken_withScopeList_inClaims() {
            String token = buildJwt(Instant.now().plusSeconds(3600).getEpochSecond(),
                "\"scp\":[\"read:items\",\"write:items\"]");
            Object scp = strategy.validate(token).getClaims().get("scp");
            assertNotNull(scp);
        }

        @Test
        void validToken_withScopeString_inClaims() {
            String token = buildJwt(Instant.now().plusSeconds(3600).getEpochSecond(),
                "\"scp\":\"read:items write:items\"");
            assertEquals("read:items write:items",
                strategy.validate(token).getClaims().get("scp"));
        }
    }

    @Nested
    class ExpiredToken {
        @Test
        void expiredToken_returnsFailure() {
            String token = buildJwt(Instant.now().minusSeconds(3600).getEpochSecond(), null);
            assertFalse(strategy.validate(token).isValid());
        }

        @Test
        void expiredToken_errorMessageContainsExpired() {
            String token = buildJwt(Instant.now().minusSeconds(3600).getEpochSecond(), null);
            assertTrue(strategy.validate(token).getErrorMessage().contains("expired"));
        }

        @Test
        void noExpClaim_returnsFailure() {
            String token = buildJwt(null, null);
            assertFalse(strategy.validate(token).isValid());
        }

        @Test
        void noExpClaim_errorMessageContainsExpired() {
            String token = buildJwt(null, null);
            assertTrue(strategy.validate(token).getErrorMessage().contains("expired"));
        }
    }

    @Nested
    class MalformedToken {
        @Test
        void twoParts_returnsFailure() {
            assertFalse(strategy.validate("header.payload").isValid());
        }

        @Test
        void fourParts_returnsFailure() {
            assertFalse(strategy.validate("a.b.c.d").isValid());
        }

        @Test
        void invalidBase64Payload_returnsFailure() {
            assertFalse(strategy.validate("header.!!!.sig").isValid());
        }

        @Test
        void malformedToken_errorMessageContainsMalformed() {
            ValidationResult result = strategy.validate("header.payload");
            assertTrue(result.getErrorMessage().contains("Malformed"));
        }
    }

    @Nested
    class DecodePayload {
        @Test
        void validJwt_decodesCorrectly() {
            String token = buildJwt(Instant.now().plusSeconds(3600).getEpochSecond(), null);
            Map<String, Object> claims = strategy.decodePayload(token);
            assertEquals("user@example.com", claims.get("sub"));
        }

        @Test
        void wrongPartCount_throwsIllegalArgument() {
            assertThrows(IllegalArgumentException.class,
                () -> strategy.decodePayload("only.two"));
        }
    }

    @Nested
    class IsExpired {
        @Test
        void futureExp_returnsFalse() {
            Map<String, Object> claims = new HashMap<>();
            claims.put("exp", (int)(Instant.now().plusSeconds(3600).getEpochSecond()));
            assertFalse(strategy.isExpired(claims));
        }

        @Test
        void pastExp_returnsTrue() {
            Map<String, Object> claims = new HashMap<>();
            claims.put("exp", (int)(Instant.now().minusSeconds(3600).getEpochSecond()));
            assertTrue(strategy.isExpired(claims));
        }

        @Test
        void missingExp_returnsTrue() {
            assertTrue(strategy.isExpired(new HashMap<>()));
        }

        @Test
        void expAsLong_handledCorrectly() {
            Map<String, Object> claims = new HashMap<>();
            claims.put("exp", Instant.now().plusSeconds(3600).getEpochSecond());
            assertFalse(strategy.isExpired(claims));
        }
    }
}

