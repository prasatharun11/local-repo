}

// =============================================================================
// ValidationResult
// =============================================================================

class ValidationResult {

    private final boolean valid;
    private final Map<String, Object> claims;
    private final String errorMessage;

    private ValidationResult(boolean valid, Map<String, Object> claims, String errorMessage) {
        this.valid        = valid;
        this.claims       = claims;
        this.errorMessage = errorMessage;
    }

    static ValidationResult success(Map<String, Object> claims) {
        return new ValidationResult(true, claims, null);
    }

    static ValidationResult failure(String errorMessage) {
        return new ValidationResult(false, null, errorMessage);
    }

    public boolean isValid()                    { return valid; }
    public Map<String, Object> getClaims()      { return claims; }
    public String getErrorMessage()             { return errorMessage; }
}

// =============================================================================
// ValidationStrategy — interface
// =============================================================================

interface ValidationStrategy {
    ValidationResult validate(String token);
}

// =============================================================================
// UriValidationStrategy
// Checks: RS256 Signature + Issuer + Audience + Expiry
// Uses Okta's AccessTokenVerifier — tries each issuer URI until one matches.
// =============================================================================

class UriValidationStrategy implements ValidationStrategy {

    private static final Logger log = LoggerFactory.getLogger(UriValidationStrategy.class);

    private final List<AccessTokenVerifier> verifiers;

    UriValidationStrategy(List<AccessTokenVerifier> verifiers) {
        if (CollectionUtils.isEmpty(verifiers)) {
            throw new IllegalArgumentException(
                "UriValidationStrategy requires at least one AccessTokenVerifier."
            );
        }
        this.verifiers = verifiers;
        log.info("UriValidationStrategy initialized with {} verifier(s).", verifiers.size());
    }

    @Override
    public ValidationResult validate(String token) {
        log.debug("URI strategy: validating against {} issuer(s).", verifiers.size());
        for (int i = 0; i < verifiers.size(); i++) {
            try {
                com.okta.jwt.Jwt jwt = verifiers.get(i).decode(token);
                log.debug("URI strategy: accepted by verifier #{} (of {}).", i + 1, verifiers.size());
                return ValidationResult.success(new HashMap<>(jwt.getClaims()));
            } catch (JwtVerificationException e) {
                log.trace("URI strategy: verifier #{} rejected — {}", i + 1, e.getMessage());
            }
        }
        return ValidationResult.failure("Token rejected by all configured issuer URI verifiers.");
    }
}

// =============================================================================
// JwksValidationStrategy
// Checks: RS256 Signature + Audience + Expiry (no issuer check)
// Uses Spring's NimbusJwtDecoder pointed directly at each JWKS URI.
// =============================================================================

class JwksValidationStrategy implements ValidationStrategy {

    private static final Logger log = LoggerFactory.getLogger(JwksValidationStrategy.class);

    private final List<JwtDecoder> decoders;
    private final String expectedAudience;

    JwksValidationStrategy(List<JwtDecoder> decoders, String expectedAudience) {
        if (CollectionUtils.isEmpty(decoders)) {
            throw new IllegalArgumentException(
                "JwksValidationStrategy requires at least one JwtDecoder."
            );
        }
        this.decoders          = decoders;
        this.expectedAudience  = expectedAudience;
        log.info("JwksValidationStrategy initialized with {} decoder(s), audience: {}.",
            decoders.size(), expectedAudience);
    }

    @Override
    public ValidationResult validate(String token) {
        log.debug("JWKS strategy: validating against {} decoder(s).", decoders.size());
        for (int i = 0; i < decoders.size(); i++) {
            try {
                org.springframework.security.oauth2.jwt.Jwt jwt = decoders.get(i).decode(token);

                if (expectedAudience != null && !jwt.getAudience().contains(expectedAudience)) {
                    log.trace("JWKS strategy: decoder #{} — audience mismatch, expected '{}'.",
                        i + 1, expectedAudience);
                    continue;
                }

                log.debug("JWKS strategy: accepted by decoder #{} (of {}).", i + 1, decoders.size());
                return ValidationResult.success(new HashMap<>(jwt.getClaims()));

            } catch (org.springframework.security.oauth2.jwt.JwtException e) {
                log.trace("JWKS strategy: decoder #{} rejected — {}", i + 1, e.getMessage());
            }
        }
        return ValidationResult.failure("Token rejected by all configured JWKS URI decoders.");
    }
}

// =============================================================================
// ExpiryOnlyValidationStrategy
// Checks: Expiry only — base64-decodes the JWT payload and reads the exp claim.
// No signature, issuer, or audience verification performed.
// =============================================================================

class ExpiryOnlyValidationStrategy implements ValidationStrategy {

    private static final Logger log = LoggerFactory.getLogger(ExpiryOnlyValidationStrategy.class);
    private static final ObjectMapper MAPPER = new ObjectMapper();

    ExpiryOnlyValidationStrategy() {
        log.info("ExpiryOnlyValidationStrategy initialized — expiry check only.");
    }

    @Override
    public ValidationResult validate(String token) {
        try {
            Map<String, Object> claims = decodePayload(token);

            if (isExpired(claims)) {
                log.warn("Expiry-only strategy: token is expired.");
                return ValidationResult.failure("Token has expired.");
            }

            log.debug("Expiry-only strategy: token is valid (not expired).");
            return ValidationResult.success(claims);

        } catch (IllegalArgumentException e) {
            log.warn("Expiry-only strategy: malformed token — {}", e.getMessage());
            return ValidationResult.failure("Malformed token: " + e.getMessage());
        }
    }

    @SuppressWarnings("unchecked")
    Map<String, Object> decodePayload(String token) {
        String[] parts = token.split("\\.");
        if (parts.length != 3) {
            throw new IllegalArgumentException("JWT must have exactly 3 parts.");
        }
        try {
            byte[] payloadBytes = Base64.getUrlDecoder().decode(parts[1]);
            return MAPPER.readValue(payloadBytes, Map.class);
        } catch (Exception e) {
            throw new IllegalArgumentException("Failed to decode JWT payload: " + e.getMessage());
        }
    }

    boolean isExpired(Map<String, Object> claims) {
        Object exp = claims.get("exp");
        if (exp == null) {
            log.warn("Expiry-only strategy: no exp claim found — treating as expired.");
            return true;
        }
        long expEpoch = ((Number) exp).longValue();
        return Instant.now().isAfter(Instant.ofEpochSecond(expEpoch));
    }
}

// =============================================================================
// OktaJwtAuthFilter — OncePerRequestFilter
// Delegates all token validation to the injected ValidationStrategy.
// =============================================================================

class OktaJwtAuthFilter extends OncePerRequestFilter {

    private static final Logger log = LoggerFactory.getLogger(OktaJwtAuthFilter.class);
    private static final String BEARER_PREFIX = "Bearer ";

    private final ValidationStrategy strategy;

    OktaJwtAuthFilter(ValidationStrategy strategy) {
        if (strategy == null) {
            throw new IllegalArgumentException("ValidationStrategy must not be null.");
        }
        this.strategy = strategy;
        log.info("OktaJwtAuthFilter initialized with strategy: {}",
            strategy.getClass().getSimpleName());
    }

    @Override
    protected void doFilterInternal(HttpServletRequest request,
                                    HttpServletResponse response,
                                    FilterChain filterChain)
            throws ServletException, IOException {

        String authHeader = request.getHeader(HttpHeaders.AUTHORIZATION);

        if (authHeader == null || !authHeader.startsWith(BEARER_PREFIX)) {
            filterChain.doFilter(request, response);
            return;
        }

        String token = authHeader.substring(BEARER_PREFIX.length()).trim();
        ValidationResult result = strategy.validate(token);

        if (result.isValid()) {
            setAuthentication(result.getClaims(), token);
            log.debug("Token validated for subject '{}' on {} {}",
                result.getClaims().get("sub"), request.getMethod(), request.getRequestURI());
            filterChain.doFilter(request, response);
        } else {
            log.warn("Token validation failed on {} {}: {}",
                request.getMethod(), request.getRequestURI(), result.getErrorMessage());
            sendUnauthorized(response, result.getErrorMessage());
        }
    }

    private void setAuthentication(Map<String, Object> claims, String rawToken) {
        String subject = (String) claims.get("sub");
        List<SimpleGrantedAuthority> authorities = extractAuthorities(claims);
        SecurityContextHolder.getContext().setAuthentication(
            new UsernamePasswordAuthenticationToken(subject, rawToken, authorities)
        );
    }

    @SuppressWarnings("unchecked")
    private List<SimpleGrantedAuthority> extractAuthorities(Map<String, Object> claims) {
        Object scp = claims.get("scp");

        if (scp instanceof List) {
            return ((List<String>) scp).stream()
                .map(scope -> new SimpleGrantedAuthority("SCOPE_" + scope))
                .collect(Collectors.toList());
        }
        if (scp instanceof String) {
            return Arrays.stream(((String) scp).split("\\s+"))
                .map(scope -> new SimpleGrantedAuthority("SCOPE_" + scope))
                .collect(Collectors.toList());
        }

        return Collections.emptyList();
    }

    private void sendUnauthorized(HttpServletResponse response, String message) throws IOException {
        SecurityContextHolder.clearContext();
        response.setStatus(HttpStatus.UNAUTHORIZED.value());
        response.setContentType("application/json");
        response.getWriter().write(
            "{\"error\": \"Unauthorized\", \"message\": \"" + message + "\"}"
        );
    }
}

// =============================================================================
// WebSecurityConfig
// =============================================================================

@Configuration
@EnableWebSecurity
@EnableMethodSecurity
@EnableConfigurationProperties(OktaProperties.class)
public class WebSecurityConfig {

    private static final Logger log = LoggerFactory.getLogger(WebSecurityConfig.class);

    private final OktaProperties oktaProperties;

    public WebSecurityConfig(OktaProperties oktaProperties) {
        this.oktaProperties = oktaProperties;
    }

    @Bean
    public ValidationStrategy validationStrategy() {
        if (!oktaProperties.isIssuerValidation()) {
            log.info("Issuer validation DISABLED — using ExpiryOnlyValidationStrategy.");
            return new ExpiryOnlyValidationStrategy();
        }

        String type = oktaProperties.getValidationType();

        if ("uri".equalsIgnoreCase(type)) {
            log.info("Validation type: URI — using UriValidationStrategy.");
            return new UriValidationStrategy(buildUriVerifiers());
        }

        if ("jwks".equalsIgnoreCase(type)) {
            log.info("Validation type: JWKS — using JwksValidationStrategy.");
            return new JwksValidationStrategy(buildJwksDecoders(), oktaProperties.getAudience());
        }

        throw new IllegalStateException(
            "Unknown okta.validation-type: '" + type + "'. Supported values: 'uri', 'jwks'."
        );
    }

    @Bean
    public OktaJwtAuthFilter oktaJwtAuthFilter() {
        return new OktaJwtAuthFilter(validationStrategy());
    }

    @Bean
    public SecurityFilterChain securityFilterChain(HttpSecurity http) throws Exception {
        http
            .sessionManagement(session ->
                session.sessionCreationPolicy(SessionCreationPolicy.STATELESS))
            .csrf(csrf -> csrf.disable())
            .formLogin(form -> form.disable())
            .httpBasic(basic -> basic.disable())
            .authorizeHttpRequests(auth -> auth
                .requestMatchers("/actuator/health", "/public/**").permitAll()
                .anyRequest().authenticated()
            )
            .addFilterBefore(oktaJwtAuthFilter(), UsernamePasswordAuthenticationFilter.class);

        return http.build();
    }

    private List<AccessTokenVerifier> buildUriVerifiers() {
        List<String> uris = oktaProperties.getIssuerUris();
        if (CollectionUtils.isEmpty(uris)) {
            throw new IllegalStateException(
                "okta.issuer-uris must contain at least one entry when validation-type is 'uri'."
            );
        }
        return uris.stream()
            .map(uri -> JwtVerifiers.accessTokenVerifierBuilder()
                .setIssuer(uri.trim())
                .setAudience(oktaProperties.getAudience())
                .build())
            .collect(Collectors.toList());
    }

    private List<JwtDecoder> buildJwksDecoders() {
        List<String> uris = oktaProperties.getJwksUris();
        if (CollectionUtils.isEmpty(uris)) {
            throw new IllegalStateException(
                "okta.jwks-uris must contain at least one entry when validation-type is 'jwks'."
            );
        }
        return uris.stream()
            .map(uri -> {
                NimbusJwtDecoder decoder = NimbusJwtDecoder.withJwkSetUri(uri.trim()).build();
                decoder.setJwtValidator(new DelegatingOAuth2TokenValidator<>(
                    new JwtTimestampValidator()
                ));
                return (JwtDecoder) decoder;
            })
            .collect(Collectors.toList());
    }
}



