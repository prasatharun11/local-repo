// PatternValidationStrategyTest — pure unit test, no Spring context
// =============================================================================

class PatternValidationStrategyTest {

    private PatternValidationStrategy strategy;

    private String buildJwt(Long exp, String issuer) {
        String header  = Base64.getUrlEncoder().withoutPadding()
            .encodeToString("{\"alg\":\"RS256\"}".getBytes());
        String payloadJson = "{\"sub\":\"user@example.com\""
            + (issuer != null ? ",\"iss\":\"" + issuer + "\"" : "")
            + (exp    != null ? ",\"exp\":" + exp             : "")
            + "}";
        String payload = Base64.getUrlEncoder().withoutPadding()
            .encodeToString(payloadJson.getBytes());
        return header + "." + payload + ".fakesig";
    }

    @Nested
    class Constructor {
        @Test void throwsWhenPatternNull()  { assertThrows(IllegalArgumentException.class, () -> new PatternValidationStrategy(null)); }
        @Test void throwsWhenPatternBlank() { assertThrows(IllegalArgumentException.class, () -> new PatternValidationStrategy("  ")); }
        @Test void succeedsWithPattern()    { assertDoesNotThrow(() -> new PatternValidationStrategy("*.abc.com")); }
    }

    @Nested
    class MatchesPattern {

        @BeforeEach
        void setUp() { strategy = new PatternValidationStrategy("*.abc.com"); }

        @Test void subdomain_matches()                { assertTrue(strategy.matchesPattern("https://dev.abc.com/oauth2/default")); }
        @Test void deepSubdomain_matches()            { assertTrue(strategy.matchesPattern("https://dev.okta.abc.com/oauth2/default")); }
        @Test void differentDomain_noMatch()          { assertFalse(strategy.matchesPattern("https://dev.xyz.com/oauth2/default")); }
        @Test void exactDomain_noMatch()              { assertFalse(strategy.matchesPattern("https://abc.com/oauth2/default")); }
        @Test void nullIssuer_returnsFalse()          { assertFalse(strategy.matchesPattern(null)); }
        @Test void malformedUri_returnsFalse()        { assertFalse(strategy.matchesPattern("not a uri")); }
        @Test void pathIsIgnored_onlyHostMatters()    { assertTrue(strategy.matchesPattern("https://dev.abc.com/some/deep/path")); }
        @Test void caseInsensitive()                  { assertTrue(strategy.matchesPattern("https://DEV.ABC.COM/oauth2/default")); }

        @Test
        void exactPatternWithoutWildcard() {
            PatternValidationStrategy exact = new PatternValidationStrategy("auth.abc.com");
            assertTrue(exact.matchesPattern("https://auth.abc.com/oauth2/default"));
            assertFalse(exact.matchesPattern("https://dev.abc.com/oauth2/default"));
        }
    }

    @Nested
    class ValidToken {

        @BeforeEach
        void setUp() { strategy = new PatternValidationStrategy("*.abc.com"); }

        @Test
        void validIssuerAndExpiry_returnsSuccess() {
            assertTrue(strategy.validate(buildJwt(
                Instant.now().plusSeconds(3600).getEpochSecond(),
                "https://dev.abc.com/oauth2/default")).isValid());
        }

        @Test
        void subjectInClaims() {
            assertEquals("user@example.com", strategy.validate(buildJwt(
                Instant.now().plusSeconds(3600).getEpochSecond(),
                "https://dev.abc.com/oauth2/default")).getClaims().get("sub"));
        }

        @Test
        void issuerInClaims() {
            assertEquals("https://dev.abc.com/oauth2/default", strategy.validate(buildJwt(
                Instant.now().plusSeconds(3600).getEpochSecond(),
                "https://dev.abc.com/oauth2/default")).getClaims().get("iss"));
        }
    }

    @Nested
    class InvalidToken {

        @BeforeEach
        void setUp() { strategy = new PatternValidationStrategy("*.abc.com"); }

        @Test
        void expiredToken_returnsFailure() {
            ValidationResult r = strategy.validate(buildJwt(
                Instant.now().minusSeconds(3600).getEpochSecond(),
                "https://dev.abc.com/oauth2/default"));
            assertFalse(r.isValid());
            assertTrue(r.getErrorMessage().contains("expired"));
        }

        @Test
        void noExpClaim_returnsFailure() {
            assertFalse(strategy.validate(buildJwt(null, "https://dev.abc.com/oauth2/default")).isValid());
        }

        @Test
        void issuerDoesNotMatchPattern_returnsFailure() {
            ValidationResult r = strategy.validate(buildJwt(
                Instant.now().plusSeconds(3600).getEpochSecond(),
                "https://dev.xyz.com/oauth2/default"));
            assertFalse(r.isValid());
            assertTrue(r.getErrorMessage().contains("does not match"));
        }

        @Test
        void missingIssuerClaim_returnsFailure() {
            ValidationResult r = strategy.validate(buildJwt(
                Instant.now().plusSeconds(3600).getEpochSecond(), null));
            assertFalse(r.isValid());
            assertTrue(r.getErrorMessage().contains("missing"));
        }

        @Test
        void malformedToken_returnsFailure() {
            ValidationResult r = strategy.validate("not.valid");
            assertFalse(r.isValid());
            assertTrue(r.getErrorMessage().contains("Malformed"));
        }
    }

    @Nested
    class IsExpired {

        @BeforeEach
        void setUp() { strategy = new PatternValidationStrategy("*.abc.com"); }

        @Test void futureExpAsInt_returnsFalse() {
            Map<String, Object> c = new HashMap<>();
            c.put("exp", (int) Instant.now().plusSeconds(3600).getEpochSecond());
            assertFalse(strategy.isExpired(c));
        }

        @Test void futureExpAsLong_returnsFalse() {
            Map<String, Object> c = new HashMap<>();
            c.put("exp", Instant.now().plusSeconds(3600).getEpochSecond());
            assertFalse(strategy.isExpired(c));
        }

        @Test void pastExp_returnsTrue() {
            Map<String, Object> c = new HashMap<>();
            c.put("exp", (int) Instant.now().minusSeconds(3600).getEpochSecond());
            assertTrue(strategy.isExpired(c));
        }

        @Test void missingExp_returnsTrue() { assertTrue(strategy.isExpired(new HashMap<>())); }
    }
}

